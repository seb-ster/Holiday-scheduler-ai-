<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <Color x:Key="PrimaryColor">#006A67</Color>
    <Color x:Key="PrimaryContainerColor">#9CF1ED</Color>
    <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
    <Color x:Key="AccentColor">#7B5800</Color>
    <Color x:Key="BackgroundColor">#F4F7F6</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceMutedColor">#EAF2F1</Color>
    <Color x:Key="OutlineColor">#C8D3D1</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="{DynamicResource PrimaryContainerColor}" />
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="{DynamicResource OnPrimaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{DynamicResource SurfaceMutedColor}" />
    <SolidColorBrush x:Key="OutlineBrush" Color="{DynamicResource OutlineColor}" />
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window">
      <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
      <Setter Property="FontFamily" Value="Segoe UI, Noto Sans, sans-serif" />
    </Style>

    <Style Selector="TextBlock.headline">
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="BorderBrush" Value="{DynamicResource OutlineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="Button.filled">
      <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.tonal">
      <Setter Property="Background" Value="{DynamicResource PrimaryContainerBrush}" />
      <Setter Property="Foreground" Value="#00201F" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="ToggleButton.chip">
      <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource OutlineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="ToggleButton.chip:checked">
      <Setter Property="Background" Value="{DynamicResource PrimaryContainerBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    </Style>
  </Application.Styles>
</Application>
