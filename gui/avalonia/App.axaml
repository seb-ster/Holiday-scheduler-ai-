<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HolidayScheduler.Gui.App">
  <Application.Resources>
    <Color x:Key="PrimaryColor">#0A84FF</Color>
    <Color x:Key="PrimaryContainerColor">#EAF3FF</Color>
    <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
    <Color x:Key="AccentColor">#6E6E73</Color>
    <Color x:Key="BackgroundColor">#F5F5F7</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceMutedColor">#F2F2F4</Color>
    <Color x:Key="OutlineColor">#B8B8B8</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="{DynamicResource PrimaryContainerColor}" />
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="{DynamicResource OnPrimaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{DynamicResource SurfaceMutedColor}" />
    <SolidColorBrush x:Key="OutlineBrush" Color="{DynamicResource OutlineColor}" />
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window">
      <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
      <Setter Property="FontFamily" Value="-apple-system, BlinkMacSystemFont, SF Pro Text, Helvetica Neue, sans-serif" />
    </Style>

    <Style Selector="TextBlock.headline">
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="BorderBrush" Value="{DynamicResource OutlineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="14" />
    </Style>

    <Style Selector="Button.filled">
      <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <Style Selector="Button.tonal">
      <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}" />
      <Setter Property="Foreground" Value="#1D1D1F" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource OutlineBrush}" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <Style Selector="TabStripItem">
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="Margin" Value="0,0,4,0" />
      <Setter Property="Foreground" Value="#8E8E93" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="TabStripItem:selected">
      <Setter Property="Foreground" Value="#1D1D1F" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
    </Style>

    <Style Selector="ToggleButton.chip">
      <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource OutlineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="ToggleButton.chip:checked">
      <Setter Property="Background" Value="{DynamicResource PrimaryContainerBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    </Style>
  </Application.Styles>
</Application>
