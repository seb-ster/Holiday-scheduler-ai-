<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:anim="clr-namespace:Avalonia.Animation;assembly=Avalonia.Base"
        x:Class="HolidayScheduler.Gui.MainWindow"
        Title="Holiday Scheduler Demonstrator"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="620">
  <Grid RowDefinitions="Auto,*" Margin="24">
    <Border Classes="card" Padding="18,14" Margin="0,0,0,16">
      <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
        <StackPanel Spacing="2">
          <TextBlock Text="Yearly Roster" Classes="headline" />
          <TextBlock x:Name="YearLabel" Opacity="0.72" />
        </StackPanel>

        <TextBlock Grid.Column="1" x:Name="PageIndicator"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold" />

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
          <Button x:Name="PreviousPageButton" Classes="tonal" Content="Previous" Click="OnPreviousPage" />
          <Button x:Name="NextPageButton" Classes="filled" Content="Next" Click="OnNextPage" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Classes="card" Padding="0" ClipToBounds="True">
      <Carousel x:Name="RosterCarousel">
        <Carousel.PageTransition>
          <anim:PageSlide Duration="0:0:0.30" Orientation="Horizontal" />
        </Carousel.PageTransition>

        <Carousel.ItemTemplate>
          <DataTemplate>
            <Grid RowDefinitions="Auto,*" Margin="16">
              <Grid ColumnDefinitions="80,*,*,*,*" Margin="0,0,0,8">
                <Border Grid.Column="0" Background="{DynamicResource SurfaceMutedBrush}" Padding="8" CornerRadius="8" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1">
                  <TextBlock Text="Day" FontWeight="SemiBold" HorizontalAlignment="Center" />
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="8" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Month1Name}" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#00201F" />
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="8" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Month2Name}" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#00201F" />
                </Border>
                <Border Grid.Column="3" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="8" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Month3Name}" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#00201F" />
                </Border>
                <Border Grid.Column="4" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="8" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Month4Name}" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#00201F" />
                </Border>
              </Grid>

              <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding Rows}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="80,*,*,*,*" Margin="0,0,0,6">
                        <Border Grid.Column="0" Background="{DynamicResource SurfaceMutedBrush}" Padding="8" CornerRadius="8" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1">
                          <TextBlock Text="{Binding DayLabel}" HorizontalAlignment="Center" />
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" Padding="8" CornerRadius="8" Margin="8,0,0,0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1">
                          <TextBlock Text="{Binding Month1Status}" HorizontalAlignment="Center" FontSize="12" />
                        </Border>
                        <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" Padding="8" CornerRadius="8" Margin="8,0,0,0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1">
                          <TextBlock Text="{Binding Month2Status}" HorizontalAlignment="Center" FontSize="12" />
                        </Border>
                        <Border Grid.Column="3" Background="{DynamicResource SurfaceBrush}" Padding="8" CornerRadius="8" Margin="8,0,0,0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1">
                          <TextBlock Text="{Binding Month3Status}" HorizontalAlignment="Center" FontSize="12" />
                        </Border>
                        <Border Grid.Column="4" Background="{DynamicResource SurfaceBrush}" Padding="8" CornerRadius="8" Margin="8,0,0,0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1">
                          <TextBlock Text="{Binding Month4Status}" HorizontalAlignment="Center" FontSize="12" />
                        </Border>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </DataTemplate>
        </Carousel.ItemTemplate>
      </Carousel>
    </Border>
  </Grid>
</Window>
