<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HolidayScheduler.Gui.MainWindow"
        Title="Holiday Scheduler Demonstrator"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="620">
  <DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="Help">
        <MenuItem Header="Version" Name="VersionMenuItem" />
        <MenuItem Header="Licenses" Name="LicensesMenuItem" />
      </MenuItem>
    </Menu>
    <Grid Background="#FFFFFF">
      <TextBlock Text="Holiday Scheduler Demonstrator"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 FontSize="32"
                 Foreground="#222222" />
    </Grid>
  </DockPanel>
</Window>