<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HolidayScheduler.Gui.MainWindow"
        Title="Holiday Scheduler Demonstrator"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="620">
  <Grid RowDefinitions="Auto,Auto,*" Margin="24">
    <!-- Status Bar -->
    <Border Grid.Row="0" x:Name="StatusBar" Background="#E8F5E9" BorderBrush="#A5D6A7" BorderThickness="1" CornerRadius="0" Padding="0" Height="48" Margin="0,0,0,12" IsVisible="False">
      <Grid ColumnDefinitions="*,Auto,Auto" Margin="16,0">
        <!-- Status Message -->
        <TextBlock Grid.Column="0" Grid.ColumnSpan="3" x:Name="StatusMessage" Text="Row pinned" Foreground="#2E7D32" FontWeight="Medium" VerticalAlignment="Center" HorizontalAlignment="Center" />

        <!-- Countdown Timer -->
        <TextBlock Grid.Column="1" x:Name="StatusCountdown" Text="2" Foreground="#2E7D32" Opacity="0.75" FontSize="13" VerticalAlignment="Center" Margin="0,0,16,0" />

        <!-- Dismiss Button with Progress Fill -->
        <Border Grid.Column="2" x:Name="StatusCloseButton" Padding="0" Margin="8,4,0,4" CornerRadius="0" Cursor="Hand" ToolTip.Tip="Dismiss (auto-closing)" ToolTip.Placement="Top" ToolTip.VerticalOffset="-5" BorderThickness="1.5" BorderBrush="#A5D6A7" Background="#E8F5E9" Width="82" Height="32">
          <Grid>
            <!-- Progress Fill Background (animates from 0 to full width) -->
            <Canvas ClipToBounds="True">
              <Rectangle x:Name="StatusProgressFill" Canvas.Left="0" Canvas.Top="0" Width="0" Height="32" Fill="#C8E6C9" RadiusX="0" RadiusY="0" />
            </Canvas>
            
            <!-- Dismiss Label -->
            <TextBlock x:Name="StatusCloseLabel" Text="Schließen" Foreground="#2E7D32" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1" Classes="card" Padding="18,14" Margin="0,0,0,16">
      <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
        <StackPanel Spacing="2">
          <TextBlock Text="Yearly Roster" Classes="headline" />
          <TextBlock x:Name="YearLabel" Opacity="0.72" Text="Roster year" />
          <Border x:Name="UpdateTestModeBadge" IsVisible="False" Background="#FFF4CE" BorderBrush="#E1B95D" BorderThickness="1" CornerRadius="6" Padding="6,2" Margin="0,4,0,0" HorizontalAlignment="Left">
            <TextBlock x:Name="UpdateTestModeBadgeText" Text="TEST MODE" FontSize="11" FontWeight="SemiBold" Foreground="#7A4F00" />
          </Border>
          <TextBlock x:Name="UpdateTestModeHelpText"
                     IsVisible="False"
                     MaxWidth="560"
                     TextWrapping="Wrap"
                     FontSize="11"
                     Foreground="#7A4F00"
                     Text="Sie sind im Testmodus. Das ist nur zum Prüfen der Update-Anzeige. Im normalen Betrieb sucht die App nach echten Updates und lädt nur herunter, wenn wirklich eine neue Version verfügbar ist." />
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <Button x:Name="StatusPositiveButton" Classes="filled" Content="Positive" MinWidth="88" />
          <Button x:Name="StatusNegativeButton" Classes="tonal" Content="Negative" MinWidth="88" />
          <Button x:Name="StatusNeutralButton" Classes="tonal" Content="Neutral" MinWidth="88" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="2" Classes="card" Padding="0" ClipToBounds="True">
      <Grid RowDefinitions="Auto,*" Margin="12">
        <Grid ColumnDefinitions="Auto,Auto" Margin="4,4,4,10">
          <TabStrip x:Name="YearTabStrip" Grid.Column="0" Margin="0">
            <TabStripItem x:Name="YearTab0" />
            <TabStripItem x:Name="YearTab1" />
            <TabStripItem x:Name="YearTab2" />
            <TabStripItem x:Name="YearTab3" />
            <TabStripItem x:Name="YearTab4" />
          </TabStrip>
          <Button x:Name="TodayButton" Grid.Column="1" Classes="tonal" Content="Today" MinWidth="88" Margin="8,0,0,0" />
        </Grid>

        <ContentControl Grid.Row="1" x:Name="YearContent">
          <ContentControl.ContentTemplate>
            <DataTemplate>
              <Grid RowDefinitions="Auto,*" Margin="16,12">
              <Grid ColumnDefinitions="40,92,*,*,*,*,*,*,*,*,*,*,*,*" Margin="0,0,0,8">
                <Border Grid.Column="0" Background="{DynamicResource SurfaceMutedBrush}" Padding="4" CornerRadius="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1">
                </Border>
                <Border Grid.Column="1" Background="#E6EDF7" Padding="8" CornerRadius="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1">
                  <TextBlock Text="DATE" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#0F2A44" />
                </Border>

                <Border Grid.Column="2" Classes="monthCol1" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month1Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="3" Classes="monthCol2" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month2Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="4" Classes="monthCol3" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month3Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="5" Classes="monthCol4" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month4Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="6" Classes="monthCol5" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month5Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="7" Classes="monthCol6" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month6Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="8" Classes="monthCol7" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month7Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="9" Classes="monthCol8" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month8Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="10" Classes="monthCol9" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month9Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="11" Classes="monthCol10" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month10Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="12" Classes="monthCol11" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month11Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="13" Classes="monthCol12" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1"><TextBlock Text="{Binding Month12Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
              </Grid>

              <Border Grid.Row="1" Classes="card" Padding="6" Margin="0,2,0,0">
              <ScrollViewer HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="RosterListBox" ItemsSource="{Binding Rows}" BorderThickness="0" Background="Transparent" SelectionMode="Single">
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                      <Setter Property="Padding" Value="0" />
                      <Setter Property="Margin" Value="0" />
                      <Setter Property="Cursor" Value="Hand" />
                    </Style>
                    <Style Selector="ListBoxItem:not(:selected):pointerover Border.rowTrack">
                      <Setter Property="Background" Value="#EEF5FF" />
                    </Style>
                    <Style Selector="ListBoxItem:selected Border.rowTrack">
                      <Setter Property="Background" Value="#DCEBFF" />
                    </Style>
                    <Style Selector="ListBoxItem:selected Grid.rowAccent">
                      <Setter Property="Opacity" Value="1.0" />
                    </Style>
                    <Style Selector="ListBoxItem:selected TextBlock.dayLabel">
                      <Setter Property="Foreground" Value="#0F4EA9" />
                    </Style>
                    <Style Selector="ListBox.monthCol1Active Border.monthCol1"><Setter Property="Background" Value="#BED7FF" /></Style>
                    <Style Selector="ListBox.monthCol2Active Border.monthCol2"><Setter Property="Background" Value="#BED7FF" /></Style>
                    <Style Selector="ListBox.monthCol3Active Border.monthCol3"><Setter Property="Background" Value="#BED7FF" /></Style>
                    <Style Selector="ListBox.monthCol4Active Border.monthCol4"><Setter Property="Background" Value="#BED7FF" /></Style>
                    <Style Selector="ListBox.monthCol5Active Border.monthCol5"><Setter Property="Background" Value="#BED7FF" /></Style>
                    <Style Selector="ListBox.monthCol6Active Border.monthCol6"><Setter Property="Background" Value="#BED7FF" /></Style>
                    <Style Selector="ListBox.monthCol7Active Border.monthCol7"><Setter Property="Background" Value="#BED7FF" /></Style>
                    <Style Selector="ListBox.monthCol8Active Border.monthCol8"><Setter Property="Background" Value="#BED7FF" /></Style>
                    <Style Selector="ListBox.monthCol9Active Border.monthCol9"><Setter Property="Background" Value="#BED7FF" /></Style>
                    <Style Selector="ListBox.monthCol10Active Border.monthCol10"><Setter Property="Background" Value="#BED7FF" /></Style>
                    <Style Selector="ListBox.monthCol11Active Border.monthCol11"><Setter Property="Background" Value="#BED7FF" /></Style>
                    <Style Selector="ListBox.monthCol12Active Border.monthCol12"><Setter Property="Background" Value="#BED7FF" /></Style>
                    <Style Selector="ListBoxItem:not(:selected) Border.iconCell:pointerover Grid.pinHover">
                      <Setter Property="Opacity" Value="0.7" />
                    </Style>
                    <Style Selector="ListBoxItem:selected Border.iconCell Grid.pinStuck">
                      <Setter Property="Opacity" Value="1.0" />
                    </Style>
                    <Style Selector="Grid.pinHover">
                      <Setter Property="IsVisible" Value="True" />
                    </Style>
                    <Style Selector="Grid.pinStuck">
                      <Setter Property="IsVisible" Value="False" />
                    </Style>
                    <Style Selector="ListBoxItem:selected Grid.pinHover">
                      <Setter Property="IsVisible" Value="False" />
                    </Style>
                    <Style Selector="ListBoxItem:selected Grid.pinStuck">
                      <Setter Property="IsVisible" Value="True" />
                    </Style>
                  </ListBox.Styles>

                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Classes="rowTrack" Background="Transparent">
                        <Grid ColumnDefinitions="40,92,*,*,*,*,*,*,*,*,*,*,*,*" Margin="0,0,0,0">
                          <Border Grid.Column="0" Classes="iconCell" Background="#EEF2F7" Padding="6" Margin="3,2,3,2" CornerRadius="4" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Cursor="Hand" ToolTip.Tip="Click to keep this date highlighted" ToolTip.Placement="Top" ToolTip.VerticalOffset="-5">
                            <Grid Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                              <!-- Hovering pin icon - visible when not selected -->
                              <Grid Classes="pinHover" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Back square (shadow) -->
                                <Rectangle Fill="#E0E0E0" Width="10" Height="10" Opacity="0.5" />
                                <!-- Front square (highlight) -->
                                <Rectangle Fill="#DCEBFF" Width="10" Height="10" Stroke="#0A84FF" StrokeThickness="0.5" Opacity="0.6" />
                                <!-- Pin body (vertical line) -->
                                <Line StartPoint="0,0" EndPoint="0,8" Stroke="#8E8E93" StrokeThickness="1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,2,0,0" Opacity="0.7" />
                                <!-- Pin head (red circle) -->
                                <Ellipse Fill="#FF3B30" Width="3" Height="3" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.8" />
                              </Grid>
                              <!-- Pinned icon - visible when selected -->
                              <Grid Classes="pinStuck" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Back square (darker) -->
                                <Rectangle Fill="#BED7FF" Width="10" Height="10" Opacity="0.8" />
                                <!-- Front square (active highlight) -->
                                <Rectangle Fill="#0A84FF" Width="10" Height="10" Stroke="#0A5BC4" StrokeThickness="0.8" Opacity="0.95" />
                                <!-- Pin body (darker) -->
                                <Line StartPoint="0,0" EndPoint="0,8" Stroke="#0A5BC4" StrokeThickness="1.2" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,2,0,0" Opacity="0.95" />
                                <!-- Pin head (red circle, darker) -->
                                <Ellipse Fill="#FF3B30" Width="3" Height="3" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.95" />
                              </Grid>
                            </Grid>
                          </Border>
                          <Border Grid.Column="1" Classes="dayCell" Background="#EEF2F7" Padding="0" CornerRadius="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1">
                            <Grid ColumnDefinitions="Auto,*">
                              <!-- Fixed-row indicator - pin showing row is pinned -->
                              <Grid Grid.Column="0" Classes="rowAccent" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0,0,0" Opacity="0">
                                <!-- Back square -->
                                <Rectangle Fill="#0A5BC4" Width="7" Height="7" Opacity="0.8" />
                                <!-- Front square (active highlight) -->
                                <Rectangle Fill="#0A5BC4" Width="7" Height="7" Opacity="0.95" />
                                <!-- Pin body -->
                                <Line StartPoint="0,0" EndPoint="0,5" Stroke="#0A5BC4" StrokeThickness="0.8" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,1,0,0" Opacity="0.95" />
                                <!-- Pin head -->
                                <Ellipse Fill="#FF3B30" Width="2" Height="2" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,0,0" Opacity="0.95" />
                              </Grid>
                              <TextBlock Grid.Column="1" Classes="dayLabel" Text="{Binding DayLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#142A3B" />
                            </Grid>
                          </Border>

                          <Border Grid.Column="2" Classes="monthCol1" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1">
                            <TextBlock Text="{Binding Month1Status}" ToolTip.Tip="{Binding Month1Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/>
                          </Border>
                          <Border Grid.Column="3" Classes="monthCol2" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month2Status}" ToolTip.Tip="{Binding Month2Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="4" Classes="monthCol3" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month3Status}" ToolTip.Tip="{Binding Month3Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="5" Classes="monthCol4" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month4Status}" ToolTip.Tip="{Binding Month4Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="6" Classes="monthCol5" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month5Status}" ToolTip.Tip="{Binding Month5Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="7" Classes="monthCol6" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month6Status}" ToolTip.Tip="{Binding Month6Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="8" Classes="monthCol7" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month7Status}" ToolTip.Tip="{Binding Month7Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="9" Classes="monthCol8" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month8Status}" ToolTip.Tip="{Binding Month8Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="10" Classes="monthCol9" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month9Status}" ToolTip.Tip="{Binding Month9Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="11" Classes="monthCol10" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month10Status}" ToolTip.Tip="{Binding Month10Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="12" Classes="monthCol11" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month11Status}" ToolTip.Tip="{Binding Month11Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="13" Classes="monthCol12" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,1,1"><TextBlock Text="{Binding Month12Status}" ToolTip.Tip="{Binding Month12Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </ScrollViewer>
              </Border>
            </Grid>
            </DataTemplate>
          </ContentControl.ContentTemplate>
        </ContentControl>
      </Grid>
    </Border>

    <!-- Main menu overlay: near-transparent so the content behind bleeds through, giving a floating panel feel -->
    <Border x:Name="MainMenuOverlay" Grid.RowSpan="3" Background="#50000000" IsVisible="False">
      <Grid>
        <Border x:Name="MainMenuPanel" Width="760" MaxWidth="900" Padding="0" CornerRadius="14" Background="#F5F5F7" BorderBrush="#D8D8DC" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0" BoxShadow="0 12 60 0 #00000045">
          <Border.Styles>
            <Style Selector="Border.menuCard">
              <Setter Property="Background" Value="#FFFFFF" />
              <Setter Property="BorderBrush" Value="#E4E4EA" />
              <Setter Property="Opacity" Value="1" />
              <Setter Property="Transitions">
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.14" Easing="CubicEaseOut" />
                </Transitions>
              </Setter>
            </Style>
            <Style Selector="Border.menuCard:pointerover">
              <Setter Property="Opacity" Value="0.93" />
            </Style>
          </Border.Styles>
          <Grid RowDefinitions="Auto,Auto,Auto">
            <!-- Header Section -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="24,22,24,24">
              <Button x:Name="MainMenuCloseButton"
                      Grid.Column="0"
                      Width="14"
                      Height="14"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Background="#FF5F57"
                      BorderBrush="#E0443E"
                      BorderThickness="1"
                      CornerRadius="7"
                      Foreground="#802420"
                      FontSize="10"
                      FontWeight="Bold"
                      Content="×"
                      Padding="0"
                      ToolTip.Tip="Menü schließen" />
              <StackPanel Grid.Column="1" Spacing="6" Margin="16,8,16,0">
                <TextBlock Text="Main Menu" FontSize="26" FontWeight="SemiBold" Foreground="#1A1A1E" />
                <TextBlock Text="Select a data source to get started." FontSize="13" Foreground="#7A7A8A" />
              </StackPanel>
            </Grid>

            <!-- Cards Section -->
            <StackPanel Grid.Row="1" Spacing="12" Margin="32,0,32,28">
              <!-- Roster Card -->
              <Border Classes="menuCard" BorderThickness="1" Padding="22" CornerRadius="10" BoxShadow="0 2 8 0 #00000012">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="Roster" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1E" />
                    <TextBlock Text="Load a yearly roster configuration file." FontSize="12" Foreground="#7A7A8A" />
                  </StackPanel>
                  <Button Grid.Column="1" x:Name="ImportRosterButton" Classes="filled" Content="Import" MinWidth="110" Margin="20,0,0,0" VerticalAlignment="Center" />
                </Grid>
              </Border>

              <!-- Requests Card -->
              <Border Classes="menuCard" BorderThickness="1" Padding="22" CornerRadius="10" BoxShadow="0 2 8 0 #00000012">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="Requests" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1E" />
                    <TextBlock Text="Load employee holiday request data." FontSize="12" Foreground="#7A7A8A" />
                  </StackPanel>
                  <Button Grid.Column="1" x:Name="ImportRequestsButton" Classes="tonal" Content="Import" MinWidth="110" Margin="20,0,0,0" VerticalAlignment="Center" />
                </Grid>
              </Border>

              <!-- Constraints Card -->
              <Border Classes="menuCard" BorderThickness="1" Padding="22" CornerRadius="10" BoxShadow="0 2 8 0 #00000012">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="Constraints" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1E" />
                    <TextBlock Text="Load scheduling constraints and rules." FontSize="12" Foreground="#7A7A8A" />
                  </StackPanel>
                  <Button Grid.Column="1" x:Name="ImportConstraintsButton" Classes="tonal" Content="Import" MinWidth="110" Margin="20,0,0,0" VerticalAlignment="Center" />
                </Grid>
              </Border>
            </StackPanel>

            <!-- Footer Section -->
            <StackPanel Grid.Row="2" Spacing="12" Margin="32,0,32,22">
              <!-- Startup preference card -->
              <Border Classes="menuCard" BorderThickness="1" Padding="16" CornerRadius="10" BoxShadow="0 2 8 0 #00000012">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="Startup" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1E" />
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <CheckBox x:Name="DontShowOnStartupCheckBox" />
                      <TextBlock Text="Don't show on startup" FontSize="12" Foreground="#8A8A9A" VerticalAlignment="Center" />
                    </StackPanel>
                  </StackPanel>
                </Grid>
              </Border>

              <!-- New session card -->
              <Border Classes="menuCard" BorderThickness="1" Padding="16" CornerRadius="10" BoxShadow="0 2 8 0 #00000012">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="Session" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1E" />
                    <TextBlock Text="Start with a fresh workspace state." FontSize="12" Foreground="#7A7A8A" />
                  </StackPanel>
                  <Button Grid.Column="1" x:Name="StartFreshButton" Classes="tonal" Content="New session" MinWidth="120" Margin="20,0,0,0" VerticalAlignment="Center" />
                </Grid>
              </Border>

              <!-- Feedback card -->
              <Border Classes="menuCard" BorderThickness="1" Padding="16" CornerRadius="10" BoxShadow="0 2 8 0 #00000012">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="Feedback" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1E" />
                    <TextBlock Text="Send comments, problems, or improvement ideas." FontSize="12" Foreground="#7A7A8A" />
                  </StackPanel>
                  <Button Grid.Column="1" x:Name="FeedbackButton" Classes="tonal" Content="Send feedback" MinWidth="140" Margin="20,0,0,0" VerticalAlignment="Center" />
                </Grid>
              </Border>

              <!-- Quit card -->
              <Border Classes="menuCard" BorderThickness="1" Padding="16" CornerRadius="10" BoxShadow="0 2 8 0 #00000012">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="Application" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1E" />
                    <TextBlock Text="Close the demonstrator." FontSize="12" Foreground="#7A7A8A" />
                  </StackPanel>
                  <Button Grid.Column="1" x:Name="QuitButton" Classes="tonal" Content="Quit" MinWidth="110" Margin="20,0,0,0" VerticalAlignment="Center" />
                </Grid>
              </Border>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
