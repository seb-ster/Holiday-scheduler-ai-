<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HolidayScheduler.Gui.MainWindow"
        Title="Holiday Scheduler Demonstrator"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="620">
  <Grid RowDefinitions="Auto,Auto,*" Margin="24">
    <!-- Status Bar -->
    <Border Grid.Row="0" x:Name="StatusBar" Background="#E8F5E9" BorderBrush="#A5D6A7" BorderThickness="1" CornerRadius="0" Padding="0" Height="48" Margin="0,0,0,12" IsVisible="False">
      <Grid ColumnDefinitions="*,Auto,Auto" Margin="16,0">
        <!-- Status Message -->
        <TextBlock Grid.Column="0" x:Name="StatusMessage" Text="Row pinned" Foreground="#2E7D32" FontWeight="Medium" VerticalAlignment="Center" />

        <!-- Countdown Timer -->
        <TextBlock Grid.Column="1" x:Name="StatusCountdown" Text="2" Foreground="#2E7D32" Opacity="0.75" FontSize="13" VerticalAlignment="Center" Margin="0,0,16,0" />

        <!-- Dismiss Button with Progress Fill -->
        <Border Grid.Column="2" x:Name="StatusCloseButton" Padding="0" Margin="8,4,0,4" CornerRadius="0" Cursor="Hand" ToolTip.Tip="Dismiss (auto-closing)" ToolTip.Placement="Top" ToolTip.VerticalOffset="-5" BorderThickness="1.5" BorderBrush="#A5D6A7" Background="#E8F5E9" Width="82" Height="32">
          <Grid>
            <!-- Progress Fill Background (animates from 0 to full width) -->
            <Canvas ClipToBounds="True">
              <Rectangle x:Name="StatusProgressFill" Canvas.Left="0" Canvas.Top="0" Width="0" Height="32" Fill="#C8E6C9" RadiusX="0" RadiusY="0" />
            </Canvas>
            
            <!-- Dismiss Label -->
            <TextBlock x:Name="StatusCloseLabel" Text="Dismiss" Foreground="#2E7D32" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1" Classes="card" Padding="18,14" Margin="0,0,0,16">
      <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
        <StackPanel Spacing="2">
          <TextBlock Text="Yearly Roster" Classes="headline" />
          <TextBlock x:Name="YearLabel" Opacity="0.72" Text="Roster year" />
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <Button x:Name="TodayButton" Classes="tonal" Content="Today" MinWidth="88" />
          <Button x:Name="StatusPositiveButton" Classes="filled" Content="Positive" MinWidth="88" />
          <Button x:Name="StatusNegativeButton" Classes="tonal" Content="Negative" MinWidth="88" />
          <Button x:Name="StatusNeutralButton" Classes="tonal" Content="Neutral" MinWidth="88" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="2" Classes="card" Padding="0" ClipToBounds="True">
      <Grid RowDefinitions="Auto,*" Margin="12">
        <TabStrip x:Name="YearTabStrip" Margin="4,4,4,10">
          <TabStripItem x:Name="YearTab0" />
          <TabStripItem x:Name="YearTab1" />
          <TabStripItem x:Name="YearTab2" />
          <TabStripItem x:Name="YearTab3" />
          <TabStripItem x:Name="YearTab4" />
        </TabStrip>

        <ContentControl Grid.Row="1" x:Name="YearContent">
                    <ContentControl.PageTransition>
                      <CompositePageTransition>
                        <PageTransition>
                          <CrossFade Duration="0:0:0.15" />
                        </PageTransition>
                        <PageTransition>
                          <PageSlide Duration="0:0:0.2" Orientation="Horizontal" />
                        </PageTransition>
                      </CompositePageTransition>
                    </ContentControl.PageTransition>
          <ContentControl.ContentTemplate>
            <DataTemplate>
              <Grid RowDefinitions="Auto,*" Margin="4">
              <Grid ColumnDefinitions="40,92,*,*,*,*,*,*,*,*,*,*,*,*" Margin="0,0,0,8">
                <Border Grid.Column="0" Background="{DynamicResource SurfaceMutedBrush}" Padding="4" CornerRadius="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1">
                </Border>
                <Border Grid.Column="1" Background="#E6EDF7" Padding="8" CornerRadius="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1">
                  <TextBlock Text="DATE" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#0F2A44" />
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month1Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="3" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month2Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="4" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month3Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="5" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month4Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="6" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month5Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="7" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month6Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="8" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month7Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="9" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month8Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="10" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month9Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="11" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month10Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="12" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,1,0,1"><TextBlock Text="{Binding Month11Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
                <Border Grid.Column="13" Background="{DynamicResource PrimaryContainerBrush}" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1"><TextBlock Text="{Binding Month12Name}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#00201F"/></Border>
              </Grid>

              <Grid Grid.Row="1">
                <ListBox x:Name="RosterListBox" ItemsSource="{Binding Rows}" BorderThickness="0" Background="Transparent" SelectionMode="Single">
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                      <Setter Property="Padding" Value="0" />
                      <Setter Property="Margin" Value="0" />
                      <Setter Property="Cursor" Value="Hand" />
                    </Style>
                    <Style Selector="ListBoxItem:not(:selected):pointerover Border.rowTrack">
                      <Setter Property="Background" Value="#EEF5FF" />
                    </Style>
                    <Style Selector="ListBoxItem:selected Border.rowTrack">
                      <Setter Property="Background" Value="#DCEBFF" />
                    </Style>
                    <Style Selector="ListBoxItem:selected Canvas.rowAccent">
                      <Setter Property="Opacity" Value="1.0" />
                    </Style>
                    <Style Selector="ListBoxItem:selected TextBlock.dayLabel">
                      <Setter Property="Foreground" Value="#0F4EA9" />
                    </Style>
                    <Style Selector="ListBoxItem:not(:selected) Border.iconCell:pointerover Canvas.pinHover">
                      <Setter Property="Opacity" Value="0.7" />
                    </Style>
                    <Style Selector="ListBoxItem:selected Border.iconCell Canvas.pinStuck">
                      <Setter Property="Opacity" Value="1.0" />
                    </Style>
                    <Style Selector="Canvas.pinHover">
                      <Setter Property="IsVisible" Value="True" />
                    </Style>
                    <Style Selector="Canvas.pinStuck">
                      <Setter Property="IsVisible" Value="False" />
                    </Style>
                    <Style Selector="ListBoxItem:selected Canvas.pinHover">
                      <Setter Property="IsVisible" Value="False" />
                    </Style>
                    <Style Selector="ListBoxItem:selected Canvas.pinStuck">
                      <Setter Property="IsVisible" Value="True" />
                    </Style>
                  </ListBox.Styles>

                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Classes="rowTrack" Background="Transparent">
                        <Grid ColumnDefinitions="40,92,*,*,*,*,*,*,*,*,*,*,*,*" Margin="0,0,0,0">
                          <Border Grid.Column="0" Classes="iconCell" Background="#EEF2F7" Padding="7" Margin="3,2,3,2" CornerRadius="4" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Cursor="Hand" ToolTip.Tip="Highlight row" ToolTip.Placement="Top" ToolTip.VerticalOffset="-5">
                            <Grid Width="26" Height="26">
                              <!-- Hovering pin icon -->
                              <Canvas Classes="pinHover" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0" Opacity="0.85">
                                <Path Fill="#5A6B7D" Data="M11 2 L11 18 M11 2 L6 6 M11 2 L16 6" StrokeThickness="2" Stroke="#5A6B7D" />
                              </Canvas>
                              <!-- Pinned icon sits lower to indicate fixation -->
                              <Canvas Classes="pinStuck" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,3,0,0" Opacity="1.0">
                                <Path Fill="#3A4B5D" Data="M11 2 L11 18 M11 2 L6 6 M11 2 L16 6" StrokeThickness="2" Stroke="#3A4B5D" />
                              </Canvas>
                            </Grid>
                          </Border>
                          <Border Grid.Column="1" Classes="dayCell" Background="#EEF2F7" Padding="0" CornerRadius="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1">
                            <Grid ColumnDefinitions="Auto,*">
                              <!-- Down-facing pin indicator -->
                              <Canvas Grid.Column="0" Classes="rowAccent" Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0,0,0" Opacity="0">
                                <Path Fill="#0A84FF" Data="M6 4 L6 10 M6 10 L3 7 M6 10 L9 7" StrokeThickness="1.5" Stroke="#0A84FF" />
                              </Canvas>
                              <TextBlock Grid.Column="1" Classes="dayLabel" Text="{Binding DayLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#142A3B" />
                            </Grid>
                          </Border>

                          <Border Grid.Column="2" Background="Transparent" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1">
                            <TextBlock Text="{Binding Month1Status}" ToolTip.Tip="{Binding Month1Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/>
                          </Border>
                          <Border Grid.Column="3" Background="Transparent" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month2Status}" ToolTip.Tip="{Binding Month2Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="4" Background="Transparent" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month3Status}" ToolTip.Tip="{Binding Month3Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="5" Background="Transparent" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month4Status}" ToolTip.Tip="{Binding Month4Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="6" Background="Transparent" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month5Status}" ToolTip.Tip="{Binding Month5Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="7" Background="Transparent" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month6Status}" ToolTip.Tip="{Binding Month6Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="8" Background="Transparent" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month7Status}" ToolTip.Tip="{Binding Month7Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="9" Background="Transparent" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month8Status}" ToolTip.Tip="{Binding Month8Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="10" Background="Transparent" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month9Status}" ToolTip.Tip="{Binding Month9Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="11" Background="Transparent" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month10Status}" ToolTip.Tip="{Binding Month10Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="12" Background="Transparent" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,0,1"><TextBlock Text="{Binding Month11Status}" ToolTip.Tip="{Binding Month11Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                          <Border Grid.Column="13" Background="Transparent" Padding="8" CornerRadius="0" Margin="0" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1,0,1,1"><TextBlock Text="{Binding Month12Status}" ToolTip.Tip="{Binding Month12Translation}" ToolTip.Placement="Top" ToolTip.VerticalOffset="-8" HorizontalAlignment="Center" FontSize="12"/></Border>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Grid>
            </DataTemplate>
          </ContentControl.ContentTemplate>
        </ContentControl>
      </Grid>
    </Border>
  </Grid>
</Window>
