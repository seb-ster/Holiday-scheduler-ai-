<Window xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Class="HolidayScheduler.Gui.SplashWindow"
  Width="460" Height="320"
        SystemDecorations="None"
        CanResize="False"
        Background="#FFFAFAFC"
        WindowStartupLocation="CenterScreen">

  <Border CornerRadius="8" Background="#FFFFFFFF" Padding="20" BorderBrush="#FFE0E0E0" BorderThickness="1" >
    <Canvas>
      <!-- Version number overlay -->
      <TextBlock
        Text="Version 1.0.0"
        FontSize="20"
        Foreground="#666666"
        Canvas.Top="8"
        Canvas.Right="12"
        Width="120"
        HorizontalAlignment="Right"
        TextAlignment="Right"
      />

      <Grid Width="460" Height="320">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
          <!-- Simple vector logo -->
          <Canvas Width="96" Height="96">
            <Ellipse Width="96" Height="96" Fill="#3F51B5" />
            <Path Data="M24,56 C36,36 60,36 72,56 L72,68 C60,88 36,88 24,68 Z" Fill="#FFFFFF" Opacity="0.95"/>
          </Canvas>

          <TextBlock Text="Holiday Scheduler" FontSize="20" FontWeight="Bold" Foreground="#222222" HorizontalAlignment="Center"/>
          <TextBlock x:Name="SplashStatusText"
                     Text="Starte und prüfe auf Aktualisierungen..."
                     FontSize="14"
                     Foreground="#334155"
                     HorizontalAlignment="Center"
                     Margin="0,16,0,0"
                     TextWrapping="Wrap" />
        </StackPanel>

        <ProgressBar x:Name="SplashProgressBar" Grid.Row="1" IsIndeterminate="False" Minimum="0" Maximum="100" Value="10" Height="6" Margin="0,18,0,0" Foreground="#3F51B5" />
      </Grid>
    </Canvas>
  </Border>
</Window>
