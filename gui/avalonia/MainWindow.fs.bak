                importRequestPopupButton.Click.Add(fun _ ->
                    let openDialog = OpenFileDialog()
                    openDialog.Title <- "Import Request File"
                    openDialog.AllowMultiple <- false
                    openDialog.Filters.Add(FileDialogFilter(Name = "Request Files", Extensions = new System.Collections.Generic.List<string>([| "json"; "csv" |])))
                    let task: System.Threading.Tasks.Task<string[]> = openDialog.ShowAsync(this)
                    task.ContinueWith(fun (t: System.Threading.Tasks.Task<string[]>) ->
                        let files: string[] = t.Result
                        if files <> null && files.Length > 0 then
                            emptyRequestPopup.IsVisible <- false
                            showStatus (sprintf "Imported requests: %s" files.[0]) Positive) |> ignore)

            if not (isNull holidayRequestsSearchBox) then
                holidayRequestsSearchBox.TextChanged.Add(fun _ ->
                    let query = holidayRequestsSearchBox.Text.Trim().ToLowerInvariant()
                    filteredNames.Clear()
