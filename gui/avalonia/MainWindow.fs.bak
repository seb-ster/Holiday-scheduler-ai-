        // (Removed duplicate and erroneous top-level bindings)

        // Wire up FeedbackChatButton to open feedback dialog or show placeholder
        let feedbackChatButton = this.FindControl<Button>("FeedbackChatButton")
        if not (isNull feedbackChatButton) then
            feedbackChatButton.Click.Add(fun _ ->
                // Placeholder: Show simple feedback dialog
                let dialog = Window()
                dialog.Title <- "Send Feedback"
                dialog.Width <- 420.0
                dialog.Height <- 320.0
                dialog.CanResize <- false
                dialog.WindowStartupLocation <- WindowStartupLocation.CenterOwner
                dialog.Background <- SolidColorBrush(Color.Parse("#EEF3FB"))
                dialog.SystemDecorations <- SystemDecorations.Full

                let rootBorder = Border()
                rootBorder.Margin <- Avalonia.Thickness(14.0)
                rootBorder.Padding <- Avalonia.Thickness(16.0)
                rootBorder.Background <- SolidColorBrush(Color.Parse("#F8FAFF"))
                rootBorder.BorderBrush <- SolidColorBrush(Color.Parse("#9CB2D8"))
                rootBorder.BorderThickness <- Avalonia.Thickness(1.0)
                rootBorder.CornerRadius <- Avalonia.CornerRadius(10.0)

                let root = StackPanel()
                root.Spacing <- 10.0

                let titleBlock = TextBlock()
                titleBlock.Text <- "Send us your feedback!"
                titleBlock.FontSize <- 18.0
                titleBlock.FontWeight <- FontWeight.SemiBold
                titleBlock.Foreground <- SolidColorBrush(Color.Parse("#142746"))

                let message = TextBox()
                message.AcceptsReturn <- true
                message.Height <- 120.0
                message.TextWrapping <- TextWrapping.Wrap
                message.FontSize <- 14.0
                message.Margin <- Avalonia.Thickness(0.0, 2.0, 0.0, 10.0)
                message.Foreground <- SolidColorBrush(Color.Parse("#243957"))
                message.Watermark <- "Type your feedback here..."

                let sendButton = Button()
                sendButton.Content <- "Send"
                sendButton.Width <- 120.0
                sendButton.HorizontalAlignment <- Avalonia.Layout.HorizontalAlignment.Left
                sendButton.Background <- SolidColorBrush(Color.Parse("#2F4D7A"))
                sendButton.Foreground <- Brushes.White
                sendButton.Click.Add(fun _ ->
                    dialog.Close()
                    showStatus "Feedback sent! Thank you." Positive)

                root.Children.Add(titleBlock)
                root.Children.Add(message)
                root.Children.Add(sendButton)
                rootBorder.Child <- root
                dialog.Content <- rootBorder
                dialog.ShowDialog(this) |> ignore)