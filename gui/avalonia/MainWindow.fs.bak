        let showWhatsNewSummaryIfFirstStart () =
            try
                let appDataDir = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData), "HolidayScheduler")
                if not (Directory.Exists(appDataDir)) then
                    Directory.CreateDirectory(appDataDir) |> ignore
                let markerPath = Path.Combine(appDataDir, "last_seen_version.txt")
                let currentVersion = Support.currentVersionText ()
                let lastSeenVersion =
                    if File.Exists(markerPath) then File.ReadAllText(markerPath).Trim()
                    else ""
                if not (String.Equals(lastSeenVersion, currentVersion, StringComparison.Ordinal)) then
                    let headline =
                        if String.IsNullOrWhiteSpace(lastSeenVersion) then $"Willkommen in Version {currentVersion}"
                        else $"Neu in Version {currentVersion}"
                    let summaryText =
                        "Was ist neu:\n\n" +
                        "• Die App startet jetzt zuverlassiger.\n" +
                        "• Wenn etwas schieflauft, wird automatisch ein Bericht gespeichert.\n" +
                        "• Hinweise und Meldungen sind jetzt klarer und leichter zu lesen."
                    let dialog = Window()
                    dialog.Title <- headline
                    dialog.Width <- 560.0
                    dialog.Height <- 280.0
                    dialog.CanResize <- false
                    dialog.WindowStartupLocation <- WindowStartupLocation.CenterOwner
                    dialog.Background <- SolidColorBrush(Color.Parse("#EEF3FB"))
                    dialog.SystemDecorations <- SystemDecorations.Full
                    let rootBorder = Border()
                    rootBorder.Margin <- Avalonia.Thickness(14.0)
                    rootBorder.Padding <- Avalonia.Thickness(16.0)
                    rootBorder.Background <- SolidColorBrush(Color.Parse("#F8FAFF"))
                    rootBorder.BorderBrush <- SolidColorBrush(Color.Parse("#9CB2D8"))
                    rootBorder.BorderThickness <- Avalonia.Thickness(1.0)
                    rootBorder.CornerRadius <- Avalonia.CornerRadius(10.0)
                    let root = StackPanel()
                    root.Spacing <- 10.0
                    let titleBlock = TextBlock()
                    titleBlock.Text <- headline
                    titleBlock.FontSize <- 18.0
                    titleBlock.FontWeight <- FontWeight.SemiBold
                    titleBlock.Foreground <- SolidColorBrush(Color.Parse("#142746"))
                    let message = TextBlock()
                    message.Text <- summaryText
                    message.TextWrapping <- TextWrapping.Wrap
                    dialog.Content <- rootBorder
                    rootBorder.Child <- root
                    root.Children.Add(titleBlock)
                    root.Children.Add(message)
                    dialog.ShowDialog(this) |> ignore
                File.WriteAllText(markerPath, currentVersion)
            with _ -> ()
        // ...existing code...
        ()
            row.Month5Translation <- translationForStatus row.Month5Status
            row.Month6Status <- sampleForeignStatus year 6 day
            row.Month6Translation <- translationForStatus row.Month6Status
            row.Month7Status <- sampleForeignStatus year 7 day
