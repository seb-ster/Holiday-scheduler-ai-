<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HolidayScheduler.Gui.FeedbackWindow"
        Width="520"
        Height="460"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Rückmeldung senden">
  <Border Background="#F7F7FA" Padding="22">
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="14">
      <StackPanel Spacing="4">
        <TextBlock Text="Rückmeldung senden" FontSize="22" FontWeight="SemiBold" Foreground="#1A1A1E" />
        <TextBlock Text="Beschreiben Sie bitte kurz, was passiert ist oder was verbessert werden soll." FontSize="12" Foreground="#6F6F7A" TextWrapping="Wrap" />
      </StackPanel>

      <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
        <StackPanel Grid.Column="0" Spacing="6">
          <TextBlock Text="Kategorie" FontSize="12" FontWeight="SemiBold" />
          <ComboBox x:Name="FeedbackCategoryBox" SelectedIndex="0">
            <ComboBoxItem Content="Allgemein" />
            <ComboBoxItem Content="Fehler" />
            <ComboBoxItem Content="Absturz" />
            <ComboBoxItem Content="Verbesserung" />
          </ComboBox>
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="6">
          <TextBlock Text="Kontakt (optional)" FontSize="12" FontWeight="SemiBold" />
          <TextBox x:Name="FeedbackContactBox" Watermark="E-Mail oder Name" />
        </StackPanel>
      </Grid>

      <StackPanel Grid.Row="2" Spacing="6">
        <TextBlock Text="Version" FontSize="12" FontWeight="SemiBold" />
        <TextBlock x:Name="FeedbackVersionText" Text="Version 1.0.0" Foreground="#6F6F7A" />
      </StackPanel>

      <StackPanel Grid.Row="3" Spacing="6">
        <TextBlock Text="Nachricht" FontSize="12" FontWeight="SemiBold" />
        <TextBox x:Name="FeedbackMessageBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="180" Watermark="Bitte hier Ihre Rückmeldung eingeben..." />
      </StackPanel>

      <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
        <TextBlock Text="Die Rückmeldung wird lokal gespeichert und bei konfiguriertem Support-Ziel automatisch gesendet." VerticalAlignment="Center" Foreground="#6F6F7A" FontSize="11" TextWrapping="Wrap" />
        <Button Grid.Column="1" x:Name="FeedbackCancelButton" Content="Abbrechen" Classes="tonal" MinWidth="110" />
        <Button Grid.Column="2" x:Name="FeedbackSendButton" Content="Senden" Classes="filled" MinWidth="110" />
      </Grid>
    </Grid>
  </Border>
</Window>